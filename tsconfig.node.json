{
  "compilerOptions": {
    "composite": true,
    // 루트에 vite.config.js/.d.ts 를 생성하면 Vite 가 .ts 대신 그 .js(스테일)를 로드한다.
    // emit 을 버리는 outDir 로 돌려 루트 오염·셰도잉을 방지(composite 라 noEmit 불가).
    "outDir": "./node_modules/.cache/tsconfig-node",
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true
  },
  "include": ["vite.config.ts"]
}
